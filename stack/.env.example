# Copy this file to stack/.env and fill in real values before starting the stack.
# Never commit .env to version control.

# Required: Postgres connection string for postgres-exporter.
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
# Use a dedicated monitoring role with pg_monitor grant, not the app user.
# For Supabase or any remote Postgres, use sslmode=require.
POSTGRES_DSN=postgresql://monitoring:password@localhost:5432/postgres?sslmode=disable

# Optional: Seq ingest API key. Leave empty for unauthenticated local dev.
SEQ_API_KEY=

# Grafana admin credentials. Change from defaults before any shared deployment.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
