# Copy this file to stack/.env and fill in real values before starting the stack.
# Never commit .env to version control.

# Grafana admin credentials. Stack will fail to start if these are not set.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME

# Public FQDN Grafana is served from. Required behind Coolify/Traefik or
# redirects and asset links break. Leave unset for local dev (defaults to
# http://localhost:3000). Example for staging:
GF_SERVER_ROOT_URL=https://grafana-staging.socialup.bravyr.com

# Internal API key for Prometheus to scrape /metrics endpoints.
# Must match INTERNAL_API_KEY set in the socialup-api Coolify env vars.
INTERNAL_API_KEY=CHANGEME

# ---------------------------------------------------------------------------
# Frontend observability (Grafana Faro) — browser RUM ingest at
# https://obs.bravyr.com/collect. Public endpoint, basic-auth + CORS
# enforced by Coolify/Traefik.
# ---------------------------------------------------------------------------

# The public domain is configured in the Coolify UI ("Domains for alloy" =
# https://obs.bravyr.com:12347), which owns the router + TLS cert. No
# FARO_PUBLIC_HOST / FARO_BASIC_AUTH_HTPASSWD are needed any more — routing and
# auth no longer live in hand-written Traefik labels.

# Comma-separated origin allowlist enforced by faro.receiver's CORS. Must match
# the client Origin(s) exactly — no trailing slashes, no wildcards. Note the
# gb-landing Worker proxies server-to-server WITHOUT an Origin, so this only
# gates any browser that would post directly. Example for socialup:
FARO_ALLOWED_ORIGINS=https://socialup-staging.bravyr.com,https://socialup.bravyr.com

# Shared secret checked by faro.receiver against the X-API-Key header. Plain
# string — no bcrypt, no `$$` escaping. Must equal the gb-landing Worker's
# FARO_APP_KEY (Cloudflare secret) and any socialup client's key. Rotate by
# changing it here and in each client. Generate e.g. `openssl rand -base64 30`.
FARO_API_KEY=CHANGEME
# Webhook URL Grafana alerting posts to (pgBackRest PITR alerts and any
# future alert routed to the "pgbackrest-oncall" contact point --
# see grafana/provisioning/alerting/contact-points.yaml). Point this at
# whatever you actually want paged by (e.g. an Opsgenie/PagerDuty/Slack
# incoming-webhook URL, or a simple relay you control). Grafana's
# provisioning loader expands ${ENV_VAR} references in-place, so no code
# change is needed to point this elsewhere later.
ALERT_WEBHOOK_URL=https://CHANGEME.example.com/webhook
