# Copy this file to stack/.env and fill in real values before starting the stack.
# Never commit .env to version control.

# Required: Postgres connection string for postgres-exporter.
# Use a dedicated monitoring role with pg_monitor grant, not the app user.
# Local dev:  postgresql://monitoring:password@localhost:5432/postgres?sslmode=disable
# Supabase:   postgresql://monitoring:CHANGEME@db.your-project.supabase.co:5432/postgres?sslmode=require
POSTGRES_DSN=postgresql://monitoring:CHANGEME@localhost:5432/postgres?sslmode=require

# Grafana admin credentials. Stack will fail to start if these are not set.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME
